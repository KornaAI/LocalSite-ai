# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# OpenRouter API (400+ models)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Anthropic API (Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_API_BASE=https://api.anthropic.com/v1

# Google AI API (Gemini models)
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
# GOOGLE_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Mistral API
# MISTRAL_API_KEY=your_mistral_api_key_here
# MISTRAL_API_BASE=https://api.mistral.ai/v1

# Cerebras API (Fast inference)
# CEREBRAS_API_KEY=your_cerebras_api_key_here
# CEREBRAS_API_BASE=https://api.cerebras.ai/v1

# Custom OpenAI-compatible API (for other services like OpenAI, Together AI, Groq)
# OPENAI_COMPATIBLE_API_KEY=your_api_key_here
# OPENAI_COMPATIBLE_API_BASE=https://api.openai.com/v1
# Optional: If your provider does not support listing models, set a single model ID
# OPENAI_COMPATIBLE_MODEL=gpt-4

# Local AI providers
# OLLAMA_API_BASE=http://localhost:11434
# LM_STUDIO_API_BASE=http://localhost:1234/v1

# Server (adapter-node)
# HOST=0.0.0.0
# PORT=3000
# BODY_SIZE_LIMIT=100K

# Disable specific providers (comma-separated list)
# Example: DISABLED_PROVIDERS=ollama,lm_studio
# DISABLED_PROVIDERS=

# Default Provider (deepseek, openrouter, anthropic, google, mistral, cerebras, openai_compatible, ollama, lm_studio)
DEFAULT_PROVIDER=ollama
