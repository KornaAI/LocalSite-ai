{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite dev",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "start": "deno run -A build/index.js",
    "sync": "deno run -A --node-modules-dir npm:@sveltejs/kit sync",
    "check": "deno task sync && deno run -A --node-modules-dir npm:svelte-check --tsconfig ./tsconfig.json",
    "lint": "deno lint src/"
  },
  "exclude": [
    ".svelte-kit/",
    "build/",
    "node_modules/",
    "static/"
  ],
  "fmt": {
    "exclude": [".svelte-kit/", "build/", "node_modules/"]
  },
  "lint": {
    "exclude": [".svelte-kit/", "build/", "node_modules/"]
  }
}
